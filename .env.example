# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional overrides (defaults shown) ───────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
MAX_TOKENS=2048
SESSION_TTL_HOURS=2
SESSION_HISTORY_PAIRS=10

# ── Retrieval ─────────────────────────────────────────────────────────────────
# "hybrid" uses TF-IDF + semantic search merged with RRF (recommended)
# "semantic" uses cosine distance only (original behaviour)
RETRIEVAL_MODE=hybrid

# ── Rate Limiting ─────────────────────────────────────────────────────────────
CHAT_RATE_LIMIT=20/minute
ADMIN_RATE_LIMIT=10/minute

# ── Profile & Semantic Cache (Phase 3) ───────────────────────────────────────
PROFILE_RETENTION_YEARS=2
CACHE_HIGH_THRESHOLD=0.95
CACHE_MEDIUM_THRESHOLD=0.88

# ── Query Expansion (Phase 4A) ──────────────────────────────────────────────
USE_QUERY_EXPANSION=true
QUERY_EXPANSION_COUNT=3

# ── Contextual Compression (Phase 4B) ───────────────────────────────────────
USE_CONTEXTUAL_COMPRESSION=true
COMPRESSION_THRESHOLD=0.45
