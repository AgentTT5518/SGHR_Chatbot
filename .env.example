# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional overrides (defaults shown) ───────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
MAX_TOKENS=2048
SESSION_TTL_HOURS=2
SESSION_HISTORY_PAIRS=10

# ── Retrieval ─────────────────────────────────────────────────────────────────
# "hybrid" uses TF-IDF + semantic search merged with RRF (recommended)
# "semantic" uses cosine distance only (original behaviour)
RETRIEVAL_MODE=hybrid

# ── Rate Limiting ─────────────────────────────────────────────────────────────
CHAT_RATE_LIMIT=20/minute
ADMIN_RATE_LIMIT=10/minute
FEEDBACK_RATE_LIMIT=5/minute
PROFILE_RATE_LIMIT=10/minute

# ── Profile & Semantic Cache (Phase 3) ───────────────────────────────────────
PROFILE_RETENTION_YEARS=2
CACHE_HIGH_THRESHOLD=0.95
CACHE_MEDIUM_THRESHOLD=0.88

# ── Query Expansion (Phase 4A) ──────────────────────────────────────────────
# Expansion adds ~1.4s latency per query for <0.01 recall gain — disabled by default
USE_QUERY_EXPANSION=false
QUERY_EXPANSION_COUNT=3

# ── Contextual Compression (Phase 4B) ───────────────────────────────────────
USE_CONTEXTUAL_COMPRESSION=true
COMPRESSION_THRESHOLD=0.35

# ── Retriever Tuning ─────────────────────────────────────────────────────────
THRESHOLD_FLOOR=0.25
THRESHOLD_MULTIPLIER=1.5
RRF_K=60
MAX_RETRIEVAL_RESULTS=8

# ── Environment & Deployment ─────────────────────────────────────────────────
# "dev" | "staging" | "prod"
ENVIRONMENT=dev

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173

# Admin API key — required for all /admin/* and /metrics endpoints
# Change this in staging/prod! The default is for local development only.
ADMIN_API_KEY=dev-only-key

# HMAC secret for signing session IDs. Auto-generated if empty (dev only).
# MUST be set in staging/prod for session persistence across restarts.
SESSION_SECRET_KEY=

# Set to true in prod to reject unsigned legacy session IDs
SESSION_SIGNING_ENFORCED=false

# Set to true behind a TLS-terminating reverse proxy
ENFORCE_HTTPS=false
