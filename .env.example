# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional overrides (defaults shown) ───────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
MAX_TOKENS=2048
SESSION_TTL_HOURS=2
SESSION_HISTORY_PAIRS=10

# ── Retrieval ─────────────────────────────────────────────────────────────────
# "hybrid" uses TF-IDF + semantic search merged with RRF (recommended)
# "semantic" uses cosine distance only (original behaviour)
RETRIEVAL_MODE=hybrid

# ── Rate Limiting ─────────────────────────────────────────────────────────────
CHAT_RATE_LIMIT=20/minute
ADMIN_RATE_LIMIT=10/minute
