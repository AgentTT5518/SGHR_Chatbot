{
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(python -m pytest*)",
      "Bash(python3 -m pytest*)",
      "Bash(ruff check*)",
      "Bash(python -m mypy*)",
      "Bash(python3 -m mypy*)",
      "Bash(npm run lint*)",
      "Bash(npm run build*)",
      "Bash(npm run dev*)",
      "Bash(uvicorn backend.main:app*)",
      "Bash(pip list*)",
      "Bash(pip show*)",
      "Bash(pip3 list*)",
      "Bash(pip3 show*)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(sudo *)",
      "Bash(DROP TABLE*)",
      "Bash(DELETE FROM*)",
      "Bash(TRUNCATE*)",
      "Bash(chmod 777*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'BLOCKED=\"rm -rf|git push --force|git push -f|sudo |DROP TABLE|TRUNCATE|DELETE FROM .* WHERE 1|chmod 777\"; CMD=\"$CLAUDE_TOOL_INPUT\"; if echo \"$CMD\" | grep -qiE \"$BLOCKED\"; then echo \"BLOCKED: Tier 3 prohibited command pattern detected.\" >&2; exit 2; fi'"
          }
        ]
      }
    ]
  }
}
